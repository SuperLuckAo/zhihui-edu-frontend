{
  "name": "zhihui-edu",
  "version": "0.0.1",
  "private": true,
  "description": "智慧学院 - C端与B端前端 Monorepo",
  "scripts": {
    "dev:c": "pnpm --filter c-end dev",
    "dev:b": "pnpm --filter b-end dev",
    "build:c": "pnpm --filter c-end build",
    "build:b": "pnpm --filter b-end build",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@9.0.0"
}
